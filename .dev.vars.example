# Copy to .dev.vars for local `wrangler pages dev`. Never commit .dev.vars.
# Phase 0 only needs AUTH_TOKEN; the rest arrive in later phases.

# Server-side gate (critique 5). Any long random string for now.
AUTH_TOKEN="change-me-dev-token"

# Phase 1 LOCAL ingest only — embed.js calls Workers AI over REST.
# Account ID: Cloudflare dashboard -> Workers & Pages (right sidebar).
# API token: My Profile -> API Tokens -> Create Token with
#   "Workers AI (Read)" + "Vectorize (Edit)" permissions.
# NOT used by the deployed Function (it uses the [ai]/[[vectorize]] bindings).
CLOUDFLARE_ACCOUNT_ID=""
CLOUDFLARE_API_TOKEN=""

# Phase 3+: inference provider keys (leave blank until then).
GEMINI_API_KEY=""
GROQ_API_KEY=""
CEREBRAS_API_KEY=""

# Phase 2+ (optional): local model endpoint for Ollama/Gemma fallback.
OLLAMA_URL="http://localhost:11434"
